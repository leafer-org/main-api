{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{service_name=\"main-api\"}[1m]))",
          "legendFormat": "total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 15, "spanNulls": true }
        },
        "overrides": []
      }
    },
    {
      "title": "Request Duration (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_request_duration_seconds_bucket{service_name=\"main-api\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket{service_name=\"main-api\"}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_request_duration_seconds_bucket{service_name=\"main-api\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "spanNulls": true }
        },
        "overrides": []
      }
    },
    {
      "title": "Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{service_name=\"main-api\", http_response_status_code=~\"5..\"}[1m]))",
          "legendFormat": "5xx"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "drawStyle": "line", "fillOpacity": 20, "spanNulls": true }
        },
        "overrides": []
      }
    },
    {
      "title": "Request Duration by Route",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "topk(20, histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket{service_name=\"main-api\"}[5m])) by (le, http_route)))",
          "legendFormat": "{{http_route}}",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true } } }
      ]
    },
    {
      "title": "Node.js Heap Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "process_runtime_nodejs_memory_heap_total{service_name=\"main-api\"}",
          "legendFormat": "heap total"
        },
        {
          "expr": "process_runtime_nodejs_memory_heap_used{service_name=\"main-api\"}",
          "legendFormat": "heap used"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "spanNulls": true }
        },
        "overrides": []
      }
    },
    {
      "title": "Event Loop Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "process_runtime_nodejs_eventloop_lag{service_name=\"main-api\"}",
          "legendFormat": "event loop lag"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "spanNulls": true }
        },
        "overrides": []
      }
    },
    {
      "title": "Active Handles / Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "process_runtime_nodejs_active_handles_total{service_name=\"main-api\"}",
          "legendFormat": "active handles"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10, "spanNulls": true }
        },
        "overrides": []
      }
    },
    {
      "title": "Recent Traces",
      "type": "traces",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "tempo", "uid": "" },
      "targets": [
        {
          "queryType": "traceqlSearch",
          "filters": [
            { "id": "service-name", "tag": "service.name", "operator": "=", "value": ["main-api"], "scope": "resource" }
          ],
          "limit": 20
        }
      ]
    },
    {
      "title": "Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 34 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service_name=\"main-api\"} | json",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["nodejs", "api", "opentelemetry"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Node API Overview",
  "uid": "node-api-overview"
}
